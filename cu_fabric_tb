library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity cu_fabric_tb is
end cu_fabric_tb;

architecture tb of cu_fabric_tb is

    constant d_w : integer := 4;

    -- DUT signals
    signal clk   : STD_LOGIC := '0';

    signal ext_A : STD_LOGIC_VECTOR(d_w-1 downto 0);
    signal ext_B : STD_LOGIC_VECTOR(d_w-1 downto 0);

    signal sel_A : STD_LOGIC_VECTOR(11 downto 0);
    signal sel_B : STD_LOGIC_VECTOR(11 downto 0);

    signal Op    : STD_LOGIC_VECTOR(47 downto 0);

    -- Outputs
    signal Y00, Y01, Y02 : STD_LOGIC_VECTOR(d_w-1 downto 0);
    signal Y10, Y11, Y12 : STD_LOGIC_VECTOR(d_w-1 downto 0);
    signal Y20, Y21, Y22 : STD_LOGIC_VECTOR(d_w-1 downto 0);
    signal Y30, Y31, Y32 : STD_LOGIC_VECTOR(d_w-1 downto 0);

begin

    ------------------------------------------------------------------
    -- 🔁 Clock generation (10 ns period)
    ------------------------------------------------------------------
    clk <= not clk after 5 ns;

    ------------------------------------------------------------------
    -- 🧱 DUT
    ------------------------------------------------------------------
    DUT: entity work.cu_fabric
        port map (
            clk   => clk,
            ext_A => ext_A,
            ext_B => ext_B,
            sel_A => sel_A,
            sel_B => sel_B,
            Op    => Op,

            Y00 => Y00, Y01 => Y01, Y02 => Y02,
            Y10 => Y10, Y11 => Y11, Y12 => Y12,
            Y20 => Y20, Y21 => Y21, Y22 => Y22,
            Y30 => Y30, Y31 => Y31, Y32 => Y32
        );

    ------------------------------------------------------------------
    -- 🧪 Stimulus
    ------------------------------------------------------------------
    process
        -- helper procedure to set Op
        procedure set_op(
            signal op_vec : out STD_LOGIC_VECTOR;
            r, c : integer;
            val  : STD_LOGIC_VECTOR(3 downto 0)
        ) is
            variable idx : integer;
        begin
            idx := (r*3 + c)*4;
            op_vec(idx+3 downto idx) <= val;
        end procedure;

    begin

        ------------------------------------------------------------------
        -- 🔹 Initialize
        ------------------------------------------------------------------
        ext_A <= "1011";  -- for col0
        ext_B <= "1101";

        sel_A <= (others => '0'); -- no feedback
        sel_B <= (others => '0');

        Op <= (others => '0');

        wait for 10 ns;

        ------------------------------------------------------------------
        -- 🔹 Row 0 Ops
        ------------------------------------------------------------------
        set_op(Op,0,0,"0000"); -- AND
        set_op(Op,0,1,"0100"); -- LSL
        set_op(Op,0,2,"0010"); -- MULT

        ------------------------------------------------------------------
        -- 🔹 Row 1 Ops
        ------------------------------------------------------------------
        set_op(Op,1,0,"0011"); -- RSR
        set_op(Op,1,1,"0000"); -- NAND
        set_op(Op,1,2,"0000"); -- NOR

        ------------------------------------------------------------------
        -- 🔹 Row 2 Ops
        ------------------------------------------------------------------
        set_op(Op,2,0,"0010"); -- XOR
        set_op(Op,2,1,"0010"); -- SUB
        set_op(Op,2,2,"0011"); -- LSR

        ------------------------------------------------------------------
        -- 🔹 Row 3 Ops
        ------------------------------------------------------------------
        set_op(Op,3,0,"0100"); -- GT
        set_op(Op,3,1,"0000"); -- NAND
        set_op(Op,3,2,"0001"); -- XNOR

        ------------------------------------------------------------------
        -- 🔹 Wait for pipeline to propagate
        ------------------------------------------------------------------
        wait for 100 ns;

        ------------------------------------------------------------------
        -- 🔚 End simulation
        ------------------------------------------------------------------
        wait;

    end process;

end tb;
