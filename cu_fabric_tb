library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;
use work.cu_types.all;

entity cu_fabric_tb is
end cu_fabric_tb;

architecture tb of cu_fabric_tb is

    constant d_w : integer := 4;

    ------------------------------------------------------------------
    -- Clock
    ------------------------------------------------------------------
    signal clk : STD_LOGIC := '0';

    ------------------------------------------------------------------
    -- Inputs
    ------------------------------------------------------------------
    signal ext_A : col_array;
    signal ext_B : col_array;

    signal sel_A : STD_LOGIC_VECTOR(11 downto 0) := (others => '0');
    signal sel_B : STD_LOGIC_VECTOR(11 downto 0) := (others => '0');

    signal Op : STD_LOGIC_VECTOR(47 downto 0) := (others => '0');

    ------------------------------------------------------------------
    -- Outputs
    ------------------------------------------------------------------
    signal Y00, Y01, Y02 : STD_LOGIC_VECTOR(d_w-1 downto 0);
    signal Y10, Y11, Y12 : STD_LOGIC_VECTOR(d_w-1 downto 0);
    signal Y20, Y21, Y22 : STD_LOGIC_VECTOR(d_w-1 downto 0);
    signal Y30, Y31, Y32 : STD_LOGIC_VECTOR(d_w-1 downto 0);

begin

    ------------------------------------------------------------------
    -- Clock generation (10 ns period)
    ------------------------------------------------------------------
    clk <= not clk after 5 ns;

    ------------------------------------------------------------------
    -- DUT
    ------------------------------------------------------------------
    DUT: entity work.cu_fabric
        port map (
            clk => clk,

            ext_A => ext_A,
            ext_B => ext_B,

            sel_A => sel_A,
            sel_B => sel_B,
            Op    => Op,

            Y00 => Y00, Y01 => Y01, Y02 => Y02,
            Y10 => Y10, Y11 => Y11, Y12 => Y12,
            Y20 => Y20, Y21 => Y21, Y22 => Y22,
            Y30 => Y30, Y31 => Y31, Y32 => Y32
        );

    ------------------------------------------------------------------
    -- Stimulus
    ------------------------------------------------------------------
    process
    begin

        ------------------------------------------------------------------
        -- 🔹 Apply independent column inputs
        ------------------------------------------------------------------
        ext_A(0) <= "1011"; ext_B(0) <= "1101"; -- col0
        ext_A(1) <= "1101"; ext_B(1) <= "0010"; -- col1
        ext_A(2) <= "0011"; ext_B(2) <= "0100"; -- col2

        ------------------------------------------------------------------
        -- 🔹 Disable feedback (all from upper rows only)
        ------------------------------------------------------------------
        sel_A <= (others => '0');
        sel_B <= (others => '0');

        wait for 10 ns;

        ------------------------------------------------------------------
        -- 🔹 Row 0 Ops
        ------------------------------------------------------------------
        Op(3 downto 0)     <= "0000"; -- (0,0) AND
        Op(7 downto 4)     <= "0100"; -- (0,1) LSL
        Op(11 downto 8)    <= "0010"; -- (0,2) MULT

        ------------------------------------------------------------------
        -- 🔹 Row 1 Ops
        ------------------------------------------------------------------
        Op(15 downto 12)   <= "0011"; -- RSR
        Op(19 downto 16)   <= "0000"; -- NAND
        Op(23 downto 20)   <= "0000"; -- NOR

        ------------------------------------------------------------------
        -- 🔹 Row 2 Ops
        ------------------------------------------------------------------
        Op(27 downto 24)   <= "0010"; -- XOR
        Op(31 downto 28)   <= "0010"; -- SUB
        Op(35 downto 32)   <= "0011"; -- LSR

        ------------------------------------------------------------------
        -- 🔹 Row 3 Ops
        ------------------------------------------------------------------
        Op(39 downto 36)   <= "0100"; -- GT
        Op(43 downto 40)   <= "0000"; -- NAND
        Op(47 downto 44)   <= "0001"; -- XNOR

        ------------------------------------------------------------------
        -- 🔹 Let pipeline settle
        ------------------------------------------------------------------
        wait for 100 ns;

        ------------------------------------------------------------------
        -- End simulation
        ------------------------------------------------------------------
        wait;

    end process;

end tb;
